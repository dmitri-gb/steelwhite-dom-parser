{
  "compilerOptions": {
    "moduleResolution": "nodenext",
    "module": "nodenext",
    "lib": ["es2024", "dom"],
    "types": ["bun"],
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true
  },
  "include": ["src", "test"]
}
